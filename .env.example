DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL for metadata, sitemap, and robots (defaults to https://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Secret for POST /api/revalidate (header: x-revalidate-secret). Admin UI uses a separate authenticated endpoint.
REVALIDATE_SECRET=YOUR_REVALIDATE_SECRET_HERE

# For `bun run preview`: Wrangler reads `.dev.vars`, not `.env`. See `.dev.vars.example`.

# Wrangler bundling for OpenNext (see opennext.js.org/cloudflare/troubleshooting)
WRANGLER_BUILD_CONDITIONS=""
WRANGLER_BUILD_PLATFORM="node"

# --- Deploy from Git (recommended; build runs on Linux, not Windows) ---
# Option A: GitHub Actions — see .github/workflows/deploy-cloudflare.yml
# Option B: Cloudflare Dashboard → Workers → portfolio-next-payload → Settings → Builds
#   Build command: bun run deploy
#   Set the same env vars as GitHub secrets (DATABASE_URL, PAYLOAD_SECRET, …)
# Runtime secrets: Cloudflare Dashboard → Workers → Variables and Secrets
# Do NOT commit .open-next/ — it is built in CI.

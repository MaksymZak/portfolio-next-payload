DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL for metadata, sitemap, and robots (defaults to https://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Secret for POST /api/revalidate (header: x-revalidate-secret). Admin UI uses a separate authenticated endpoint.
REVALIDATE_SECRET=YOUR_REVALIDATE_SECRET_HERE

# OPTIONAL — only for local dev of GET /api/cv (PDF), and only if Chrome is installed in a non-standard location.
# Standard install paths are auto-detected. Safe to leave empty.
# Example (Windows): C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_EXECUTABLE_PATH=

# Vercel / serverless PDF (GET /api/cv): remote Chromium pack tar matching @sparticuz/chromium-min version.
# Must stay in sync with the package version in package.json (see Sparticuz/chromium GitHub releases).
CHROMIUM_PACK_URL=https://github.com/Sparticuz/chromium/releases/download/v149.0.0/chromium-v149.0.0-pack.x64.tar

# PRODUCTION — pre-generated CV PDFs on Cloudflare R2 (public bucket URLs).
# When set, the SAVE PDF button is a plain download link and /api/cv is never
# called (Vercel Hobby cannot fit headless Chromium in 1024 MB).
# Generate the files with `bun run cv:generate` (dev server must be running),
# upload to R2, then set these. Leave empty in local dev to keep on-demand generation.
NEXT_PUBLIC_CV_URL_EN=
NEXT_PUBLIC_CV_URL_UK=

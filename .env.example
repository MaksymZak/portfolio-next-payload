DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL for metadata, sitemap, and robots (defaults to https://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Secret for POST /api/revalidate (header: x-revalidate-secret). Admin UI uses a separate authenticated endpoint.
REVALIDATE_SECRET=YOUR_REVALIDATE_SECRET_HERE
